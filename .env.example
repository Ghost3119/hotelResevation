# ===== PostgreSQL =====
POSTGRES_DB=hotelmanager
POSTGRES_USER=hotel
POSTGRES_PASSWORD=hotel_secret_change_me
POSTGRES_PORT=5432

# ===== Backend (Spring Boot) =====
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/hotelmanager
SPRING_DATASOURCE_USERNAME=hotel
SPRING_DATASOURCE_PASSWORD=hotel_secret_change_me
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_FLYWAY_ENABLED=true

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-key-at-least-256-bits-long-for-hs256
JWT_EXPIRATION_SECONDS=3600
JWT_ISSUER=hotel-manager

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ===== Frontend (Vite) =====
VITE_API_BASE_URL=http://localhost:8080/api
FRONTEND_PORT=5173
