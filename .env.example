# ===== PostgreSQL =====
POSTGRES_DB=hotelmanager
POSTGRES_USER=hotel
POSTGRES_PASSWORD=

# ===== Backend (Spring Boot) =====
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/hotelmanager
SPRING_DATASOURCE_USERNAME=hotel
SPRING_DATASOURCE_PASSWORD=
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_FLYWAY_ENABLED=true

# JWT
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=900
JWT_ISSUER=hotel-manager

# Refresh tokens
REFRESH_TOKEN_EXPIRATION_SECONDS=604800
REFRESH_TOKEN_SECURE=false

# Security hardening
APP_SECURITY_EXPOSE_DOCS=false
APP_SECURITY_EXPOSE_H2_CONSOLE=false
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_TRACKED_KEYS=10000
TRUSTED_PROXY_CIDRS=172.16.0.0/12

# Optional, one-time local bootstrap. Values must come from an ignored .env or
# a secret manager; never put working credentials in this example file.
BOOTSTRAP_USERS_ENABLED=false
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_RECEPTIONIST_EMAIL=
BOOTSTRAP_RECEPTIONIST_PASSWORD=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGIN_PATTERNS=

# ===== Privacy =====
# Retention period (days) before a guest is anonymized by the scheduled job.
# Default 1095 = 3 years. Real retention MUST be aligned with Mexican fiscal
# obligations (CFDI, etc.) — requires legal review. See docs/privacy.md.
PRIVACY_RETENTION_DAYS=1095

# ===== Check-in / Check-out policy =====
# ER-19: early check-in. allowed=false rejects any check-in before the
# reservation checkIn time. If allowed=true, check-in is permitted up to
# early-checkin-hours before checkIn.
CHECKIN_EARLY_CHECKIN_ALLOWED=false
CHECKIN_EARLY_CHECKIN_HOURS=0
# ER-20: late check-out. allowed=false rejects any check-out after the
# reservation checkOut time. If allowed=true, check-out is permitted up to
# late-checkout-hours after checkOut.
CHECKOUT_LATE_CHECKOUT_ALLOWED=false
CHECKOUT_LATE_CHECKOUT_HOURS=0

# ===== Timezone =====
# ER-22: business dates use America/Mexico_City. Timestamps are stored as UTC
# (TIMESTAMPTZ) and the service uses this zone for LocalDate.now().
APP_TIMEZONE=America/Mexico_City

# ===== Frontend (Vite) =====
VITE_API_BASE_URL=/api
FRONTEND_PORT=5173
